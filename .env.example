# Copy this file to .env and fill in values — never commit .env

# Supabase (required)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Required: password for the CMS admin login
ADMIN_PASSWORD=

# Required: secret used to sign session tokens (random string, min 32 chars)
JWT_SECRET=

# Required for saves on Vercel: GitHub personal access token with repo write access
GITHUB_TOKEN=

# Optional: GitHub repo for CMS content saves (default: ktiwari54/TFC)
GITHUB_REPO=ktiwari54/TFC

# Optional: allowed CORS origin for API requests (default: https://tfc-mauve.vercel.app)
ALLOWED_ORIGIN=https://tfc-mauve.vercel.app

# Optional: port for local dev server (default: 8080)
PORT=8080

# Optional: set to "production" to enable Secure cookie flag
NODE_ENV=development
